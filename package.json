{
  "name": "efh-core",
  "version": "0.1.0",
  "description": "Consolidated EFH reasoning server: claim store, formal verification (Z3 / optional Prover9), sheaf ADMM consistency enforcement, gated commits",
  "type": "module",
  "bin": {
    "efh-core": "dist/index.js"
  },
