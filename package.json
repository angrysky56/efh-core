    "start": "node dist/index.js",
    "smoke": "node test/smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "z3-solver": "^4.16.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.12.0",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
